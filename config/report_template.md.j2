{% macro report_note(tag, title, body, tone='neutral') -%}
{% set tones = {
  'neutral': {
    'tag_bg': '#F1F5F9', 'tag_text': '#334155', 'head_bg': '#F8FAFC', 'border': '#E2E8F0', 'body_bg': '#FFFFFF', 'accent': '#64748B'
  },
  'accent': {
    'tag_bg': '#E0F2FE', 'tag_text': '#075985', 'head_bg': '#F8FAFC', 'border': '#BAE6FD', 'body_bg': '#F8FCFF', 'accent': '#0284C7'
  },
  'warning': {
    'tag_bg': '#FFF7ED', 'tag_text': '#C2410C', 'head_bg': '#FFFBF5', 'border': '#FED7AA', 'body_bg': '#FFFFFF', 'accent': '#EA580C'
  }
} %}
{% set palette = tones[tone] %}
<div class="report-note" style="margin:10px 0 12px 0;border:1px solid {{ palette.border }};border-left:4px solid {{ palette.accent }};border-radius:8px;overflow:hidden;background:{{ palette.body_bg }};box-shadow:0 1px 2px rgba(15,23,42,0.04);display:flex;flex-direction:column;height:100%;">
<div style="padding:10px 14px;background:{{ palette.head_bg }};border-bottom:1px solid {{ palette.border }};">
<div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
<span style="display:inline-flex;align-items:center;padding:2px 8px;border-radius:999px;background:{{ palette.tag_bg }};color:{{ palette.tag_text }};font-size:10px;font-weight:700;letter-spacing:0;">{{ tag }}</span>
<span style="font-size:12px;font-weight:600;color:#334155;">{{ title }}</span>
</div>
</div>
<div style="padding:12px 14px;font-size:13px;color:#1F2937;line-height:1.75;flex:1;">{{ body | emphasize_text | rich_text | safe }}</div>
</div>
{%- endmacro %}

{% macro summary_card(label, value, caption='', tone='neutral') -%}
{% set tones = {
  'green': {'border': '#BBF7D0', 'bg': '#F0FDF4', 'label': '#166534'},
  'yellow': {'border': '#FDE68A', 'bg': '#FFFBEB', 'label': '#92400E'},
  'red': {'border': '#FECACA', 'bg': '#FEF2F2', 'label': '#991B1B'},
  'orange': {'border': '#FED7AA', 'bg': '#FFF7ED', 'label': '#C2410C'},
  'blue': {'border': '#BAE6FD', 'bg': '#F0F9FF', 'label': '#075985'},
  'neutral': {'border': '#E2E8F0', 'bg': '#F8FAFC', 'label': '#475569'}
} %}
{% set palette = tones[tone] if tone in tones else tones['neutral'] %}
<div class="summary-card" style="min-height:86px;border:1px solid {{ palette.border }};border-radius:8px;background:{{ palette.bg }};padding:12px 14px;display:flex;flex-direction:column;justify-content:space-between;gap:8px;">
<div style="font-size:11px;font-weight:700;color:{{ palette.label }};letter-spacing:0;">{{ label }}</div>
<div style="font-size:18px;font-weight:800;color:#111827;line-height:1.25;">{{ value | safe }}</div>
{% if caption %}<div style="font-size:11px;color:#64748B;line-height:1.45;">{{ caption | safe }}</div>{% endif %}
</div>
{%- endmacro %}

{% macro inline_badge(text, tone='neutral') -%}
{% set tones = {
  'green': {'bg': '#DCFCE7', 'text': '#166534', 'border': '#BBF7D0'},
  'yellow': {'bg': '#FEF3C7', 'text': '#92400E', 'border': '#FDE68A'},
  'red': {'bg': '#FEE2E2', 'text': '#991B1B', 'border': '#FECACA'},
  'blue': {'bg': '#DBEAFE', 'text': '#1D4ED8', 'border': '#BFDBFE'},
  'orange': {'bg': '#FFEDD5', 'text': '#C2410C', 'border': '#FED7AA'},
  'neutral': {'bg': '#F1F5F9', 'text': '#475569', 'border': '#CBD5E1'}
} %}
{% set palette = tones[tone] if tone in tones else tones['neutral'] %}
<span style="display:inline-block;padding:2px 8px;border-radius:999px;background:{{ palette.bg }};color:{{ palette.text }};border:1px solid {{ palette.border }};font-size:11px;font-weight:800;line-height:1.4;">{{ text }}</span>
{%- endmacro %}

{% macro strong_value(text) -%}
<strong style="color:#111827;">{{ text }}</strong>
{%- endmacro %}

